{
  "expo": {
    "name": "AI Scan PDF",
    "slug": "aiscanpdf",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "aiscanpdf",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E27"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E27"
      },
      "package": "com.aiscanpdf.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "com.android.vending.BILLING"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiscanpdf.app",
      "infoPlist": {
        "NSCameraUsageDescription": "AI Scan PDF needs access to your camera to scan documents.",
        "NSPhotoLibraryUsageDescription": "AI Scan PDF needs access to your photos to import documents.",
        "NSMicrophoneUsageDescription": "AI Scan PDF needs microphone access for voice commands."
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AI Scan PDF to access your camera to scan documents."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow AI Scan PDF to access your photos to import documents.",
          "savePhotosPermission": "Allow AI Scan PDF to save scanned documents to your gallery."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "aiscanpdf"
      },
      "router": {
        "origin": false
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
